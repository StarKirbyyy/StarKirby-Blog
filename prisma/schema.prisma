generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  disabled
}

enum CommentStatus {
  visible
  hidden
}

enum NewsletterStatus {
  active
  unsubscribed
}

enum NewsletterCampaignStatus {
  queued
  partial
  sent
  failed
}

enum NewsletterDeliveryStatus {
  sent
  failed
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  website       String?
  role          UserRole    @default(user)
  status        UserStatus  @default(active)
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  editedPostRevisions PostRevision[] @relation("PostRevisionEditor")
  comments      Comment[]
  newsletterCampaigns NewsletterCampaign[] @relation("NewsletterCampaignCreator")
  auditLogsAsActor AuditLog[] @relation("AuditActor")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Comment {
  id        String        @id @default(cuid())
  postSlug  String
  content   String        @db.Text
  status    CommentStatus @default(visible)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([postSlug, createdAt])
  @@index([postSlug, status, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  targetType  String
  targetId    String
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  date        DateTime
  updated     DateTime?
  tags        String[] @default([])
  coverUrl    String?
  sourceUrl   String
  readingTime String
  viewCount   Int      @default(0)
  draft       Boolean  @default(false)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  revisions   PostRevision[]
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, createdAt])
  @@index([draft, date])
  @@index([viewCount])
  @@index([authorId, createdAt])
}

model PostRevision {
  id           String   @id @default(cuid())
  postId       String
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  slug         String
  title        String
  description  String
  date         DateTime
  updated      DateTime?
  tags         String[] @default([])
  coverUrl     String?
  sourceUrl    String
  readingTime  String
  draft        Boolean  @default(false)
  publishedAt  DateTime?
  editorUserId String?
  editorUser   User?    @relation("PostRevisionEditor", fields: [editorUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([postId, createdAt])
  @@index([editorUserId, createdAt])
}

model GlobalSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id             String           @id @default(cuid())
  email          String           @unique
  status         NewsletterStatus @default(active)
  source         String?
  userAgent      String?
  ipHash         String?
  subscribedAt   DateTime         @default(now())
  unsubscribedAt DateTime?
  deliveries     NewsletterDelivery[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status, subscribedAt])
  @@index([createdAt])
}

model NewsletterCampaign {
  id              String                   @id @default(cuid())
  subject         String
  bodyText        String                   @db.Text
  bodyHtml        String                   @db.Text
  provider        String
  segmentTags     String[]                 @default([])
  status          NewsletterCampaignStatus @default(queued)
  totalRecipients Int                      @default(0)
  sentCount       Int                      @default(0)
  failedCount     Int                      @default(0)
  senderEmail     String
  replyToEmail    String?
  errorSummary    String?                  @db.Text
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdByUserId String?
  createdByUser   User?                    @relation("NewsletterCampaignCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deliveries      NewsletterDelivery[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([createdByUserId, createdAt])
}

model NewsletterDelivery {
  id               String                   @id @default(cuid())
  campaignId       String
  campaign         NewsletterCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriberId     String?
  subscriber       NewsletterSubscriber?    @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  email            String
  status           NewsletterDeliveryStatus
  providerMessageId String?
  errorMessage     String?                  @db.Text
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([campaignId, email])
  @@index([campaignId, status, createdAt])
  @@index([subscriberId, createdAt])
}
